# =============================================================================
# AdVantage GTM Swarm — Environment Variables
# =============================================================================
#
# MINIMUM (works offline): no keys required — template-based swarm runs in memory
#
# AI (recommended):
#   ANTHROPIC_API_KEY   → TokenRouter key (sk-…) OR direct Claude (sk-ant-…)
#   TOKENROUTER_API_KEY → optional alias for TokenRouter
#
# SPONSOR INTEGRATIONS:
#   APIFY_API_TOKEN     → Lead Hunter: live Google/social search
#   DAYTONA_API_KEY     → Asset Builder: verify landing pages in sandbox
#
# =============================================================================

# --- Claude (TokenRouter recommended) ---
# ANTHROPIC_API_KEY=sk-...
# TOKENROUTER_API_KEY=sk-...
# TOKENROUTER_BASE_URL=https://api.tokenrouter.com/v1
# TOKENROUTER_MODEL=anthropic/claude-opus-4.7

# --- Lead Hunter ---
APIFY_API_TOKEN=apify_api_xxx

# --- Asset Builder ---
DAYTONA_API_KEY=your-daytona-api-key
DAYTONA_API_URL=https://app.daytona.io/api
DAYTONA_TARGET=us
